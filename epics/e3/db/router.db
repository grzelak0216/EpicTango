# ===== Lokalne rekordy routera =====
record(ai, "ROUTER:VERSION") {
    field(DESC, "Wersja Router IOC")
    field(VAL, "1.0")
}

record(ai, "ROUTER:STATUS") {
    field(DESC, "Status Router IOC")
    field(VAL, "1")
}

record(ao, "ROUTER:COMMAND") {
    field(DESC, "Odebrane komendy z mastera")
    field(VAL, "0")
}

record(bo, "ROUTER:CONTROL_BIT") {
    field(DESC, "Bit sterujący z mastera")
    field(VAL, "0")
}

record(waveform, "ROUTER:DATA_ARRAY") {
    field(DESC, "Tablica danych routera")
    field(FTVL, "UCHAR")
    field(NELM, "16")
}

# ===== Rekordy do odczytu z masterIOC przez PVA =====
# Używamy składni @pva:// dla linków PVA
record(ai, "MASTER:VERSION") {
    field(DESC, "Wersja Master IOC")
    field(INP, "@pva://MASTER:VERSION")
    field(SCAN, "10 second")
}

record(ai, "MASTER:STATUS") {
    field(DESC, "Status Master IOC")
    field(INP, "@pva://MASTER:STATUS")
    field(SCAN, "5 second")
}

record(waveform, "MASTER:DATA_ARRAY") {
    field(DESC, "Dane z Master IOC")
    field(FTVL, "UCHAR")
    field(NELM, "16")
    field(INP, "@pva://MASTER:DATA_ARRAY")
    field(SCAN, "1 second")
}

# ===== Rekordy do wysyłania do masterIOC przez PVA =====
record(ao, "ROUTER:COMMAND_TO_MASTER") {
    field(DESC, "Komenda do Master IOC")
    field(OUT, "@pva://MASTER:COMMAND PP")
}

record(bo, "ROUTER:CONTROL_BIT_TO_MASTER") {
    field(DESC, "Bit sterujący do Master IOC")
    field(OUT, "@pva://MASTER:CONTROL_BIT PP")
}

# ===== Status połączenia =====
record(bi, "CONNECTION_STATUS") {
    field(DESC, "Status polaczenia z Master IOC")
    field(VAL, "0")
    field(ZNAM, "Disconnected")
    field(ONAM, "Connected")
}

record(stringin, "CONNECTED_TO") {
    field(DESC, "Adres zdalnego IOC")
    field(VAL, "192.168.30.100")
}