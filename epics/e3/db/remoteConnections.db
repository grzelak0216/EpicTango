record(bi, "CONNECTION_STATUS") {
    field(DESC, "Status polaczenia z zdalnym IOC")
    field(SCAN, "1 second")
    field(INP, {"pva":{"pv":"$(REMOTE_IP):connection"}})
    field(ZNAM, "Disconnected")
    field(ONAM, "Connected")
}

record(stringin, "REMOTE_IOC_ADDR") {
    field(DESC, "Adres zdalnego IOC")
    field(VAL, "$(REMOTE_IP)")
}