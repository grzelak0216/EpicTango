#########################################################
############# MASTER IOC - REKORDY LOKALNE ##############
#########################################################

record(ai, "$(IOC):VERSION") {
    field(DESC, "Wersja $(IOC) IOC")
    field(VAL, "1.0")
}

record(ai, "$(IOC):STATUS") {
    field(DESC, "Status $(IOC) IOC")
    field(VAL, "1")
}

record(waveform, "$(IOC):DATA_ARRAY") {
    field(DESC, "Tablica danych $(IOC)")
    field(FTVL, "UCHAR")
    field(NELM, "16")
}

#########################################################
######### MASTER IOC - DANE Z ROUTERA (INPUT) ###########
#########################################################

# Krytyczne dane z routera
record(ai, "$(IOC):$(REMOTE)_VERSION") {
    field(DESC, "Wersja $(REMOTE) IOC")
    field(DTYP, "Soft Channel")
    field(SCAN, "10 second")
    field(INP, "$(REMOTE):VERSION CP")
}

record(ai, "$(IOC):$(REMOTE)_STATUS") {
    field(DESC, "Status $(REMOTE) IOC")
    field(DTYP, "Soft Channel")
    field(SCAN, "5 second")
    field(INP, "$(REMOTE):STATUS CP")
}

record(waveform, "$(IOC):$(REMOTE)_DATA") {
    field(DESC, "Dane z $(REMOTE) IOC")
    field(DTYP, "Soft Channel")
    field(FTVL, "UCHAR")
    field(NELM, "16")
    field(SCAN, "1 second")
    field(INP, "$(REMOTE):DATA_ARRAY CP")
}

#########################################################
###### MASTER IOC - KOMENDY DO ROUTERA (OUTPUT) #########
#########################################################

record(ao, "$(IOC):SEND_COMMAND") {
    field(DESC, "Wyslij komende do $(REMOTE)")
    field(DTYP, "Soft Channel")
    field(SCAN, "Passive")
    field(OUT, "$(REMOTE):RECEIVE_COMMAND PP")
}

record(bo, "$(IOC):SEND_CONTROL") {
    field(DESC, "Wyslij sterowanie do $(REMOTE)")
    field(DTYP, "Soft Channel")
    field(ZNAM, "Off")    
    field(ONAM, "On")
    field(SCAN, "Passive")
    field(OUT, "$(REMOTE):RECEIVE_CONTROL PP")
}

#########################################################
########### MASTER IOC - STATUS POLACZENIA ##############
#########################################################

record(bi, "$(IOC):CONNECTION_STATUS") {
    field(DESC, "Status polaczenia z $(REMOTE)")
    field(DTYP, "Soft Channel")
    field(ZNAM, "Disconnected")
    field(ONAM, "Connected")
    field(VAL, "0")
}

record(stringin, "$(IOC):CONNECTED_TO") {
    field(DESC, "Polaczony z IOC")
    field(VAL, "$(REMOTE_IP)")
}