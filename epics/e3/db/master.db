#########################################################
############# MASTER IOC - REKORDY LOKALNE ##############
#########################################################

record(ai, "$(IOC=MASTER):VERSION") {
    field(DESC, "Wersja $(IOC=MASTER) IOC")
    field(VAL, "1.0")
}

record(ai, "$(IOC=MASTER):STATUS") {
    field(DESC, "Status $(IOC=MASTER) IOC")
    field(VAL, "1")
}

record(waveform, "$(IOC=MASTER):DATA_ARRAY") {
    field(DESC, "Tablica danych $(IOC=MASTER)")
    field(FTVL, "UCHAR")
    field(NELM, "16")
}

#########################################################
######### MASTER IOC - DANE Z ROUTERA (INPUT) ###########
#########################################################

record(ai, "$(IOC=MASTER):$(REMOTE=ROUTER)_VERSION") {
    field(DESC, "Wersja $(REMOTE=ROUTER) IOC")
    field(DTYP, "Soft Channel")
    field(SCAN, "10 second")
    field(INP, "$(REMOTE=ROUTER):VERSION CP")
}

record(ai, "$(IOC=MASTER):$(REMOTE=ROUTER)_STATUS") {
    field(DESC, "Status $(REMOTE=ROUTER) IOC")
    field(DTYP, "Soft Channel")
    field(SCAN, "5 second")
    field(INP, "$(REMOTE=ROUTER):STATUS CP")
}

record(waveform, "$(IOC=MASTER):$(REMOTE=ROUTER)_DATA") {
    field(DESC, "Dane z $(REMOTE=ROUTER) IOC")
    field(DTYP, "Soft Channel")
    field(FTVL, "UCHAR")
    field(NELM, "16")
    field(SCAN, "1 second")
    field(INP, "$(REMOTE=ROUTER):DATA_ARRAY CP")
}

#########################################################
###### MASTER IOC - KOMENDY DO ROUTERA (OUTPUT) #########
#########################################################

record(ao, "$(IOC=MASTER):SEND_COMMAND") {
    field(DESC, "Wyslij komende do $(REMOTE=ROUTER)")
    field(DTYP, "Soft Channel")
    field(SCAN, "Passive")
    field(OUT, "$(REMOTE=ROUTER):RECEIVE_COMMAND PP")
}

record(bo, "$(IOC=MASTER):SEND_CONTROL") {
    field(DESC, "Wyslij sterowanie do $(REMOTE=ROUTER)")
    field(DTYP, "Soft Channel")
    field(ZNAM, "Off")    
    field(ONAM, "On")
    field(SCAN, "Passive")
    field(OUT, "$(REMOTE=ROUTER):RECEIVE_CONTROL PP")
}

#########################################################
########### MASTER IOC - STATUS POLACZENIA ##############
#########################################################

record(bi, "$(IOC=MASTER):CONNECTION_STATUS") {
    field(DESC, "Status polaczenia z $(REMOTE=ROUTER)")
    field(DTYP, "Soft Channel")
    field(ZNAM, "Disconnected")
    field(ONAM, "Connected")
    field(VAL, "0")
}

record(stringin, "$(IOC=MASTER):CONNECTED_TO") {
    field(DESC, "Polaczony z IOC")
    field(VAL, "$(REMOTE_IP=192.168.20.101)")
}