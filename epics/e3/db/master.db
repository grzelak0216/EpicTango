# ===== Lokalne rekordy mastera =====
record(ai, "MASTER:VERSION") {
    field(DESC, "Wersja Master IOC")
    field(VAL, "1.0")
}

record(ai, "MASTER:STATUS") {
    field(DESC, "Status Master IOC")
    field(VAL, "1")
}

record(waveform, "MASTER:DATA_ARRAY") {
    field(DESC, "Tablica danych z mastera")
    field(FTVL, "UCHAR")
    field(NELM, "16")
}

# ===== Rekordy do odczytu z routerIOC przez PVA =====
record(ai, "ROUTER:VERSION") {
    field(DESC, "Wersja Router IOC")
    field(DTYP, "pvaccess")
    field(INP, "ROUTER:VERSION")
    field(SCAN, "10 second")
}

record(ai, "ROUTER:STATUS") {
    field(DESC, "Status Router IOC")
    field(DTYP, "pvaccess")
    field(INP, "ROUTER:STATUS")
    field(SCAN, "5 second")
}

record(waveform, "ROUTER:DATA_ARRAY") {
    field(DESC, "Dane z Router IOC")
    field(DTYP, "pvaccess")
    field(FTVL, "UCHAR")
    field(NELM, "16")
    field(INP, "ROUTER:DATA_ARRAY")
    field(SCAN, "1 second")
}

# ===== Rekordy do wysyłania do routerIOC =====
record(ao, "MASTER:COMMAND") {
    field(DESC, "Komenda do Router IOC")
    field(DTYP, "pvaccess")
    field(OUT, "ROUTER:COMMAND PP")
}

record(bo, "MASTER:CONTROL_BIT") {
    field(DESC, "Bit sterujący do Router IOC")
    field(DTYP, "pvaccess")
    field(OUT, "ROUTER:CONTROL_BIT PP")
}

# ===== Status połączenia =====
record(bi, "CONNECTION_STATUS") {
    field(DESC, "Status polaczenia z Router IOC")
    field(VAL, "0")
    field(ZNAM, "Disconnected")
    field(ONAM, "Connected")
}

record(stringin, "CONNECTED_TO") {
    field(DESC, "Adres zdalnego IOC")
    field(VAL, "192.168.20.101")
}