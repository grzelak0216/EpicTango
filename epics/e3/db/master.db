# ===== Communication time =====
record(ao, "IOC1:COMM_TIME_3") {
    field(OUT, "@pva://IOC3:COMM_TIME_FROM_MASTER PP")
}
record(ao, "IOC1:COMM_TIME_4") {
    field(OUT, "@pva://IOC4:COMM_TIME_FROM_MASTER PP")
}
record(ao, "IOC1:COMM_TIME_5") {
    field(OUT, "@pva://IOC5:COMM_TIME_FROM_MASTER PP")
}

# ===== Control bit =====
record(bo, "IOC1:CONTROL") {
    field(VAL, "0")
}

record(bi, "IOC1:ACK_3") {
    field(INP, "@pva://IOC3:CONTROL_ACK CP")
}
record(bi, "IOC1:ACK_4") {
    field(INP, "@pva://IOC4:CONTROL_ACK CP")
}
record(bi, "IOC1:ACK_5") {
    field(INP, "@pva://IOC5:CONTROL_ACK CP")
}

# ===== Broadcast via IOC2 =====
record(bo, "IOC1:BIT_SET") {
    field(OUT, "@pva://IOC2:BIT_BROADCAST PP")
}

record(ao, "IOC1:ANALOG_SET") {
    field(OUT, "@pva://IOC2:ANALOG_BROADCAST PP")
}

record(waveform, "IOC1:ARRAY_SET") {
    field(FTVL, "UCHAR")
    field(NELM, "16")
    field(OUT, "@pva://IOC2:ARRAY_BROADCAST PP")
}